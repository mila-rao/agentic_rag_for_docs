# =============================================================================
# OpenAI Configuration - Required
# =============================================================================
OPENAI_API_KEY=your-api-key-here

# Optional: Custom endpoint (for Azure OpenAI or proxies)
# OPENAI_API_BASE=https://your-endpoint.openai.azure.com/

# Models
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=o3-mini

# Model parameters
# Note: For reasoning models (o1, o3, etc.) that don't support temperature or max_tokens,
# leave these empty or comment them out
OPENAI_TEMPERATURE=0.3
# OPENAI_TEMPERATURE=        # Use this for o1/o3 models

OPENAI_MAX_TOKENS=4000
# OPENAI_MAX_TOKENS=         # Use this for o1/o3 models
OPENAI_EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Retrieval Settings - Optional
# =============================================================================
# Cross-encoder reranker improves relevance but adds latency (~50ms for 20 docs)
# Runs locally, no API cost
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# =============================================================================
# Application Settings - Optional (defaults shown)
# =============================================================================
CHUNK_SIZE=512
VECTOR_COLLECTION_NAME=company_docs

# =============================================================================
# Paths - Optional (defaults shown)
# =============================================================================
DATA_DIR=./data
VECTOR_STORE_DIR=./chroma_db